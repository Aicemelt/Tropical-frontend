# ===============================
# API (DEV: Vite 프록시 사용)
# ===============================
# DEV에서는 '/api/v1' 상대경로로 호출 → vite dev proxy가 백엔드(9005)로 전달
VITE_API_BASE_URL=/api/v1

# ===============================
# Environment
# ===============================
VITE_APP_ENV=development
VITE_APP_DEBUG=true

# ===============================
# OAuth2 Login URLs (DEV: 프록시 사용)
# ===============================
# DEV에서는 절대 URL 대신 상대경로 사용 → 프록시가 9005로 전달
VITE_GOOGLE_LOGIN_URL=/oauth2/authorization/google
VITE_KAKAO_LOGIN_URL=/oauth2/authorization/kakao
VITE_NAVER_LOGIN_URL=/oauth2/authorization/naver